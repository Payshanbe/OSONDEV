# Copy to .env.local for local dev. Add the same keys in Vercel → Project → Settings → Environment Variables.

# Admin panel (/admin) — required in production
ADMIN_PASSWORD=your-secure-password
# Optional but recommended: separate signing secret (32+ random chars)
ADMIN_SECRET=your-random-secret-at-least-32-chars

# Public site URL (metadata, OG, canonical) — set to your Vercel domain after deploy
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# --- GitHub CMS (required on Vercel for admin saves) ---
# Fine-grained token: Repository access → OSONDEV, Permissions → Contents: Read and write
GITHUB_TOKEN=github_pat_xxxxxxxx
GITHUB_REPO_OWNER=Payshanbe
GITHUB_REPO_NAME=OSONDEV
# Optional, defaults to main
GITHUB_BRANCH=main

# Local dev: leave GITHUB_TOKEN unset to save files under content/ on disk.
# To test GitHub saves locally, set the variables above (use a test branch if you prefer).
